{
  "name": "tools-collection",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "routes:generate": "tsr generate",
    "build": "pnpm routes:generate && tsc -b && vite build",
    "typecheck": "pnpm routes:generate && tsc -b --noEmit",
    "lint": "oxlint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test tests/e2e/app.spec.ts",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.60.0",
    "@tanstack/router-cli": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.1.0",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
